{
    "$schema": "https://schema.railpack.com",
    "packages": {
        "php": "8.3"
    },
    "phpExtensions": ["gd", "mbstring", "pdo_mysql", "bcmath", "zip", "xml"],
    "build": {
        "cmds": [
            "composer install --no-dev --optimize-autoloader --no-interaction"
        ]
    },
    "deploy": {
        "startCmd": "php artisan migrate --force && php artisan storage:link && php artisan serve --host=0.0.0.0 --port=$PORT"
    }
}
